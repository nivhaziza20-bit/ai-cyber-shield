# ── Secrets — NEVER bake into the image ──────────────────────────────────────
.env
*.env
.env.*

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Generated reports (can be large, mounted as a volume instead) ─────────────
reports/

# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore

# ── IDE / OS noise ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Test artefacts ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
